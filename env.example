# 🔑 Environment Variables for Leftover Chef
# Copy this file to .env and fill in your credentials

# Google Gemini API Key
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# MongoDB Connection String
# Local: mongodb://localhost:27017/leftover-chef
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/leftover-chef
MONGODB_URI=mongodb://localhost:27017/leftover-chef

# Server Port
PORT=3000
